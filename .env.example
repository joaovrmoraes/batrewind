# Database driver: postgres | sqlite (default: sqlite)
DB_DRIVER=sqlite

# SQLite (used when DB_DRIVER=sqlite)
SQLITE_PATH=batrewind.db

# PostgreSQL (used when DB_DRIVER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=batrewind
DB_PASSWORD=batrewind
DB_NAME=batrewind

# Server
WRITER_PORT=8080
READER_PORT=8081
LOG_LEVEL=info

# Auth
JWT_SECRET=change-me-in-production

# Initial admin user (created on first boot if not exists)
INITIAL_OWNER_EMAIL=admin@batrewind.local
INITIAL_OWNER_PASSWORD=admin123
INITIAL_OWNER_NAME=Admin
