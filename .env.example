# Database driver: postgres | sqlite (default: sqlite)
DB_DRIVER=sqlite

# SQLite (used when DB_DRIVER=sqlite)
SQLITE_PATH=batrewind.db

# PostgreSQL (used when DB_DRIVER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=batrewind
DB_PASSWORD=batrewind
DB_NAME=batrewind

# Server
WRITER_PORT=8080
READER_PORT=8081
LOG_LEVEL=info

# Environment: set to "production" to enforce production safety checks
# (e.g. refuse to boot with the default JWT_SECRET).
ENVIRONMENT=development

# Auth — MUST be changed for production; with ENVIRONMENT=production the
# services refuse to start while this is the default value.
JWT_SECRET=change-me-in-production

# Initial admin user (created on first boot if not exists)
INITIAL_OWNER_EMAIL=admin@batrewind.local
INITIAL_OWNER_PASSWORD=admin123
INITIAL_OWNER_NAME=Admin

# CORS — comma-separated allowed origins. "*" allows any origin.
# Writer (ingest) is API-key authenticated and sends no cookies, so "*" is safe.
WRITER_CORS_ORIGINS=*
# Reader serves the dashboard API — lock this to your dashboard URL in production.
READER_CORS_ORIGINS=*

# Ingest hardening (writer)
WRITER_MAX_BODY_BYTES=5000000   # reject /record bodies larger than this (bytes) -> 413
WRITER_RATE_LIMIT_RPS=20        # per-API-key request rate; 0 disables limiting
WRITER_RATE_LIMIT_BURST=40      # per-API-key burst ceiling

# Retention (worker) — delete sessions older than N days. 0 disables purging.
RETENTION_DAYS=0
